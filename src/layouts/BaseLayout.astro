---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { 
  title = 'Rojadirecta En Vivo | Ver Fútbol Gratis Hoy',
  description = 'Ver fútbol en vivo gratis. Todos los partidos de hoy, rojadirecta, tarjeta roja, pirlo tv en vivo.',
  noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL.href} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    {noindex && <meta name="robots" content="noindex, follow" />}
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preload critical assets -->
    <link rel="preconnect" href="https://raw.githubusercontent.com" />
  </head>
  <body class="min-h-screen bg-gradient-to-b from-gray-900 via-purple-900 to-gray-900">
    <slot />
  </body>
</html>
