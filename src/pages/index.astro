---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatchCard from '../components/MatchCard.astro';
import InternalLinkBlock from '../components/InternalLinkBlock.astro';

// Fetch match data at build time
let matches = [];
try {
  const data = await fetch('https://raw.githubusercontent.com/albinchristo04/ptv/refs/heads/main/futbollibre.json');
  if (data.ok) {
    const jsonData = await data.json();
    
    // Handle both old and new API structures
    let matchesArray;
    if (Array.isArray(jsonData)) {
      matchesArray = jsonData;
    } else if (jsonData.data && Array.isArray(jsonData.data)) {
      // New structure: { metadata: {...}, data: [...] }
      matchesArray = jsonData.data;
    }
    
    if (matchesArray) {
      matches = matchesArray.map((match: any) => ({
        id: match.id || Buffer.from(match.name || match.title || Date.now().toString()).toString('base64').substring(0, 12),
        homeTeam: extractTeam(match.name, 0),
        awayTeam: extractTeam(match.name, 1),
        league: match.league || match.competition || 'Amistoso',
        localTime: convertToLocalTime(match.startTime || match.time),
        startTime: match.startTime || match.time,
        channels: match.channels || [match.iframe || match.embed].filter(Boolean),
      }));
    }
  }
} catch (error) {
  console.error('Error loading matches:', error);
}

function extractTeam(name: string, index: number): string {
  if (!name) return '';
  const parts = name.split(/-|vs|VS|\|/);
  return parts[index]?.trim() || name;
}

function convertToLocalTime(isoString: string): string {
  if (!isoString) return '';
  try {
    const date = new Date(isoString);
    return date.toLocaleString('es-ES', {
      timeZone: 'America/Mexico_City',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    });
  } catch {
    return isoString;
  }
}

const today = new Date().toLocaleDateString('es-ES', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<BaseLayout title="Rojadirecta En Vivo | Ver Fútbol Gratis Hoy - Partidos de Hoy">
