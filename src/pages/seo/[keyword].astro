---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MatchCard from '../../components/MatchCard.astro';
import InternalLinkBlock from '../../components/InternalLinkBlock.astro';

export async function getStaticPaths() {
  // Define core SEO keyword pages
  return [
    {
      params: { keyword: 'rojadirecta-en-vivo' },
      props: {
        title: 'Rojadirecta En Vivo',
        heading: '📺 Rojadirecta En Vivo | Ver Fútbol Gratis Hoy',
        description: 'Mirá fútbol en vivo gratis en Rojadirecta. Todos los partidos de hoy, transmisiones en español, sin registro. ¡Entrá ya!',
        intro: `
          <p class="mb-4">
            Bienvenido a <strong class="text-purple-300">Rojadirecta En Vivo</strong>, la mejor opción para ver fútbol en vivo gratis. 
            Aquí encontrarás todas las transmisiones deportivas en español, completamente gratis y sin necesidad de registro.
          </p>
          <p class="mb-4">
            Nuestra plataforma ofrece enlaces a múltiples señales para que puedas disfrutar de tus equipos favoritos. 
            Transmitimos partidos de <strong class="text-purple-300">La Liga</strong>, <strong class="text-purple-300">Premier League</strong>, 
            <strong class="text-purple-300">Serie A</strong>, <strong class="text-purple-300">Bundesliga</strong>, 
            <strong class="text-purple-300">Champions League</strong> y mucho más.
          </p>
          <p>
            ¿Por qué elegirnos? Porque somos rápidos, confiables y 100% gratuitos. Solo tenés que hacer clic en el partido 
            que querés ver y disfrutar del mejor fútbol europeo y sudamericano.
          </p>
        `
      }
    },
    {
      params: { keyword: 'tarjeta-roja-hoy' },
      props: {
        title: 'Tarjeta Roja Hoy | Ver Partidos En Vivo',
        heading: '🔴 Tarjeta Roja Hoy | Fútbol En Vivo Gratis',
        description: 'Tarjeta Roja hoy - Mirá todos los partidos de hoy en vivo. Transmisiones gratuitas de fútbol en español.',
        intro: `
          <p class="mb-4">
            <strong class="text-purple-300">Tarjeta Roja</strong> es tu sitio de confianza para ver fútbol en vivo hoy. 
            Ofrecemos todas las transmisiones deportivas del día, con múltiples señales para cada partido.
          </p>
          <p class="mb-4">
            Accedé a partidos de todas las ligas importantes: <strong class="text-purple-300">Liga de España</strong>, 
            <strong class="text-purple-300">Premier League inglesa</strong>, <strong class="text-purple-300">Serie A italiana</strong>, 
            <strong class="text-purple-300">Bundesliga alemana</strong> y las competiciones internacionales más importantes.
          </p>
          <p>
            Nuestro servicio es completamente gratuito y no requiere descarga. Solo seleccioná el partido que querés ver 
            y disfrutá de la mejor calidad en transmisiones deportivas.
          </p>
        `
      }
    },
    {
      params: { keyword: 'pirlo-tv-en-vivo' },
      props: {
        title: 'Pirlo TV En Vivo | Ver Fútbol Online',
        heading: '⚽ Pirlo TV En Vivo | Transmisiones Deportivas',
        description: 'Pirlo TV en vivo - La mejor programación deportiva. Mirá fútbol gratis online con todas las ligas europeas.',
        intro: `
          <p class="mb-4">
            <strong class="text-purple-300">Pirlo TV</strong> te trae la mejor programación deportiva las 24 horas. 
            Disfrutá de fútbol en vivo, resúmenes, goles y toda la acción de tus equipos favoritos.
          </p>
          <p class="mb-4">
            Encontrarás partidos de <strong class="text-purple-300">Champions League</strong>, 
            <strong class="text-purple-300">Europa League</strong>, <strong class="text-purple-300">La Liga</strong>, 
            <strong class="text-purple-300">Premier League</strong> y todos los torneos locales de Latinoamérica.
          </p>
          <p>
            La calidad de nuestras transmisiones es excelente y no necesitas registrarte. Simplemente elegí el partido 
            y empezá a disfrutar del mejor fútbol mundial.
          </p>
        `
      }
    },
    {
      params: { keyword: 'futbol-en-vivo' },
      props: {
        title: 'Fútbol En Vivo | Ver Partidos Gratis Hoy',
        heading: '⚽ Fútbol En Vivo Gratis | Todos los Partidos de Hoy',
        description: 'Ver fútbol en vivo gratis. Todos los partidos de hoy, mañana y siempre. Transmisiones en español sin costo.',
        intro: `
          <p class="mb-4">
            El mejor lugar para <strong class="text-purple-300">ver fútbol en vivo gratis</strong>. 
            Transmitimos todos los días del año, con la más amplia cobertura de ligas europeas y torneos sudamericanos.
          </p>
          <p class="mb-4">
            Disfrutá de Real Madrid, Barcelona, Manchester United, Liverpool, Juventus, Bayern Munich, Boca Juniors, 
            River Plate, Flamengo y todos los grandes clubes del mundo en acción.
          </p>
          <p>
            Nuestras transmisiones son en alta calidad, sin cortes y completamente gratuitas. 
            No te pierdas ningún gol, ninguna jugada, ninguna emoción del fútbol mundial.
