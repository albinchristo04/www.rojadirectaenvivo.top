}

const { keyword } = Astro.params;
const { title, heading, description, intro } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="container mx-auto px-4 py-8 max-w-5xl">
    <!-- Hero -->
    <section class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-center bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
        {heading}
      </h1>
      
      <div class="bg-gray-800/50 rounded-lg p-6 mb-6">
        <div class="text-gray-300 leading-relaxed" set:html={intro}></div>
      </div>
    </section>

    <!-- Featured Matches Placeholder -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
        <span class="text-purple-400">⚽</span> Partidos Destacados
      </h2>
      
      <div class="bg-gray-800/50 rounded-lg p-8 text-center">
        <p class="text-gray-400 mb-4">Los partidos se cargarán aquí automáticamente</p>
        <a href="/" class="inline-block bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold py-3 px-8 rounded-lg transition-all duration-300">
          Ver Todos los Partidos en la Homepage
        </a>
      </div>
    </section>

    <!-- Additional SEO Content -->
    <section class="bg-gray-800/30 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold mb-4">¿Cómo Ver Fútbol En Vivo Gratis?</h2>
      <div class="space-y-3 text-gray-300 text-sm">
        <p>
          Es muy sencillo. Solo seguís estos pasos:
        </p>
        <ol class="list-decimal list-inside space-y-2 ml-4">
          <li>Elegís el partido que querés ver de la lista de arriba</li>
          <li>Hacés clic en "Ver Partido"</li>
          <li>Se abrirá la página con el reproductor</li>
          <li>Seleccionás el canal que preferís (si hay varios)</li>
          <li>¡Y listo! A disfrutar del mejor fútbol</li>
        </ol>
        <p class="mt-4">
          No necesitás descargar nada, ni registrarte, ni pagar. Es 100% gratuito y seguro.
        </p>
      </div>
    </section>

    <!-- Internal Link Block (Aggressive SEO) -->
    <InternalLinkBlock variant="footer" />
  </main>
</BaseLayout>
